<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F9FC"
    tools:context=".TermsActivity">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="220dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_dashboard_header"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginStart="20dp"
            android:layout_gravity="start"
            android:layout_marginTop="16dp"
            android:background="@android:color/transparent"
            android:contentDescription="Back"
            android:src="@android:drawable/ic_media_previous"
            android:tint="@android:color/white"/>

        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginTop="12dp"
            android:contentDescription="Terms Icon"
            android:src="@drawable/ic_terms"
            android:tint="@android:color/white"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Terms &amp; Conditions"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="26sp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Please read carefully before using Smart Shelf"
            android:textColor="#E8F8FF"
            android:textSize="14sp"/>

    </LinearLayout>

    <!-- Terms Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardTerms"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        app:cardCornerRadius="22dp"
        app:cardElevation="8dp"
        android:translationY="-30dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Smart Shelf Terms &amp; Conditions"
                    android:textColor="#1E3A5F"
                    android:textStyle="bold"
                    android:textSize="22sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="1. Acceptance of Terms"
                    android:textColor="#0086C3"
                    android:textStyle="bold"
                    android:textSize="18sp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="By using Smart Shelf, you agree to comply with these Terms and Conditions. If you disagree with any part of these terms, please discontinue using the application."
                    android:textColor="#555555"
                    android:textSize="15sp"
                    android:lineSpacingExtra="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="2. User Responsibilities"
                    android:textColor="#0086C3"
                    android:textStyle="bold"
                    android:textSize="18sp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• Maintain accurate inventory information.\n\n• Keep your login credentials secure.\n\n• Do not misuse or attempt unauthorized access.\n\n• Follow all applicable laws while using Smart Shelf."
                    android:textColor="#555555"
                    android:textSize="15sp"
                    android:lineSpacingExtra="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="3. Inventory Data"
                    android:textColor="#0086C3"
                    android:textStyle="bold"
                    android:textSize="18sp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Smart Shelf securely stores your inventory information. Users are responsible for verifying the accuracy of all product details they enter."
                    android:textColor="#555555"
                    android:textSize="15sp"
                    android:lineSpacingExtra="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="4. Privacy"
                    android:textColor="#0086C3"
                    android:textStyle="bold"
                    android:textSize="18sp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Your information is handled according to the Smart Shelf Privacy Policy. Personal information will never be shared without your permission unless required by law."
                    android:textColor="#555555"
                    android:textSize="15sp"
                    android:lineSpacingExtra="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="5. Updates"
                    android:textColor="#0086C3"
                    android:textStyle="bold"
                    android:textSize="18sp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="These Terms &amp; Conditions may be updated from time to time. Continued use of Smart Shelf indicates acceptance of any updated terms."
                    android:textColor="#555555"
                    android:textSize="15sp"
                    android:lineSpacingExtra="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="6. Limitation of Liability"
                    android:textColor="#0086C3"
                    android:textStyle="bold"
                    android:textSize="18sp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Smart Shelf is provided 'as is'. The developers are not responsible for any inventory losses, business interruptions, or damages resulting from the use of this application."
                    android:textColor="#555555"
                    android:textSize="15sp"
                    android:lineSpacingExtra="4dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:gravity="center"
                    android:text="Thank you for choosing Smart Shelf."
                    android:textColor="#0086C3"
                    android:textStyle="bold"
                    android:textSize="18sp"/>

            </LinearLayout>

        </ScrollView>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>