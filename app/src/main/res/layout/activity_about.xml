<?xml version="1.0" encoding="utf-8"?>

<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="#F5F8FD"
    tools:context=".AboutActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:gravity="center"
            android:orientation="vertical"
            android:background="@drawable/bg_dashboard_header">

            <ImageView
                android:id="@+id/logo"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:src="@drawable/smart"
                app:tint="@android:color/white"/>

            <TextView
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Smart Shelf"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:textSize="30sp"/>

            <TextView
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:text="Inventory Management System"
                android:textColor="#EAF7FF"
                android:textSize="15sp"/>

            <TextView
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Version 1.0.0"
                android:textColor="#D7F5FF"
                android:textSize="13sp"/>

        </LinearLayout>

        <!-- About Card -->

        <com.google.android.material.card.MaterialCardView
            android:layout_margin="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:padding="20dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="About Smart Shelf"
                    android:textStyle="bold"
                    android:textSize="20sp"
                    android:textColor="#0A4FA8"/>

                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Smart Shelf is a premium inventory management application designed for modern businesses. Track products, manage stock, monitor reports, and organize inventory effortlessly with an intuitive and beautiful interface."
                    android:textColor="#666666"
                    android:textSize="15sp"
                    android:lineSpacingExtra="4dp"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Features -->

        <com.google.android.material.card.MaterialCardView
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:padding="20dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="Features"
                    android:textStyle="bold"
                    android:textColor="#0A4FA8"
                    android:textSize="18sp"/>

                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="✔ Product Management"
                    android:textSize="15sp"/>

                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="✔ Inventory Tracking"
                    android:textSize="15sp"/>

                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="✔ Reports &amp; Analytics"
                    android:textSize="15sp"/>

                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="✔ Category Management"
                    android:textSize="15sp"/>

                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="✔ Secure Login"
                    android:textSize="15sp"/>

                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="✔ Modern Dashboard"
                    android:textSize="15sp"/>

                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="✔ Cloud Ready"
                    android:textSize="15sp"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Technology -->

        <com.google.android.material.card.MaterialCardView
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp">

            <LinearLayout
                android:padding="20dp"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="Built With"
                    android:textStyle="bold"
                    android:textColor="#0A4FA8"
                    android:textSize="18sp"/>

                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="• Java\n• Android Studio\n• Firebase\n• Material Design\n• XML UI"
                    android:textSize="15sp"
                    android:textColor="#666"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Development Team -->

        <com.google.android.material.card.MaterialCardView
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Development Team"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#0A4FA8"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Smart Shelf is proudly designed and developed by our team with a focus on delivering a modern, reliable, and user-friendly inventory management solution."
                    android:textSize="15sp"
                    android:textColor="#666666"
                    android:lineSpacingExtra="4dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="16dp"
                    android:background="#E5E5E5"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:contentDescription="@string/aarya"
                        android:src="@drawable/ic_person"
                        android:tint="#1976D2"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Aarya Kadam"
                            android:textStyle="bold"
                            android:textSize="17sp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Backend Developer • UI/UX • Firebase"
                            android:textColor="#666666"
                            android:textSize="14sp"/>

                    </LinearLayout>

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="16dp"
                    android:background="#E5E5E5"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:contentDescription="neha"
                        android:src="@drawable/ic_person"
                        android:tint="#1976D2"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Neha Kadam"
                            android:textStyle="bold"
                            android:textSize="17sp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Frontend Development • Database • Testing"
                            android:textColor="#666666"
                            android:textSize="14sp"/>

                    </LinearLayout>

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="16dp"
                    android:background="#E5E5E5"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Together, we built Smart Shelf to simplify inventory management through an elegant interface, real-time stock monitoring, insightful reports, and secure data management."
                    android:textColor="#666666"
                    android:textSize="15sp"
                    android:lineSpacingExtra="4dp"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Buttons -->

        <LinearLayout
            android:layout_margin="16dp"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPrivacy"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="Privacy Policy"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:backgroundTint="#1976D2"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTerms"
                android:layout_marginTop="12dp"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="Terms &amp; Conditions"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:backgroundTint="#2196F3"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRate"
                android:layout_marginTop="12dp"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="Rate Smart Shelf"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:backgroundTint="#00ACC1"/>

        </LinearLayout>

        <TextView
            android:layout_height="wrap_content"
            android:layout_width="wrap_content"
            android:layout_marginBottom="30dp"
            android:layout_gravity="center"
            android:text="© 2026 Smart Shelf"
            android:textColor="#999999"
            android:textSize="13sp"/>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>