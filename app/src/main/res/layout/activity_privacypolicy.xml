<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F8FC"
    tools:context=".PrivacyPolicyActivity">

    <!-- Header -->

    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="0dp"
        android:layout_height="210dp"
        android:background="@drawable/bg_dashboard_header"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_gravity="start"
            android:layout_marginBottom="12dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_media_previous"
            app:tint="@android:color/white"/>

        <ImageView
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:src="@drawable/ic_privacy"
            android:tint="@android:color/white"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Privacy Policy"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="28sp"
            android:layout_marginTop="10dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your data, protected with care."
            android:textColor="#DCEFFF"
            android:textSize="15sp"/>

    </LinearLayout>

    <!-- Card -->

    <com.google.android.material.card.MaterialCardView

        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="18dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="10dp"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toBottomOf="@id/headerLayout"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="22dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Section -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1. Information We Collect"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="#1565C0"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Smart Shelf stores inventory information such as product names, categories, prices, stock quantity, and images. We also collect account information like your name and email address for authentication."
                    android:textColor="#666666"
                    android:textSize="15sp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="20dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2. How We Use Information"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="#1565C0"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Your information is used to manage inventory, generate reports, synchronize your data securely using Firebase, and improve the application experience."
                    android:textColor="#666666"
                    android:textSize="15sp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="20dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3. Data Security"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="#1565C0"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="We use Firebase Authentication and Firebase Database security rules to protect your information. Your data is encrypted during transmission."
                    android:textColor="#666666"
                    android:textSize="15sp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="20dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4. Third Party Services"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="#1565C0"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Smart Shelf integrates Firebase services for authentication, cloud database, and cloud storage. These services have their own privacy policies."
                    android:textColor="#666666"
                    android:textSize="15sp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="20dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5. User Rights"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="#1565C0"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="You may update or delete your account information at any time from your profile settings."
                    android:textColor="#666666"
                    android:textSize="15sp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="20dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="6. Contact Us"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="#1565C0"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="If you have questions about this Privacy Policy, please contact us through the support section of Smart Shelf."
                    android:textColor="#666666"
                    android:textSize="15sp"
                    android:layout_marginTop="8dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Last Updated: July 2026"
                    android:textAlignment="center"
                    android:textStyle="bold"
                    android:textColor="#888888"
                    android:textSize="14sp"
                    android:layout_marginTop="28dp"/>

            </LinearLayout>

        </ScrollView>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>